{
    "robot": {
        "bringup": {
            "nodes": [
                "line_sensor_driver",
                "line_follower",
                "motor_driver",
                "manual_control",
                "camera_sensor",
                "huskylens_sensor"
            ]
        }
    },
    "camera_sensor": {
        "serial": {
            "port": "/dev/ttyACM2",
            "baudrate": 115200,
            "timeout": 0.2
        },
        "publish": {
            "topic": "/face/camera"
        }
    },
    "line_sensors": {
        "serial": {
            "port": "/dev/ttyACM0",
            "baudrate": 115200,
            "timeout": 0.1
        },
        "filter": {
            "zero_hold_sec": 0.15,
            "zero_min_streak": 3
        },
        "publish": {
            "topic": "/line_sensors/frame",
            "rate_hz": 100
        },
        "topics": {
            "debug_toggle": "/debug_logs_toggle"
        }
    },
    "line_follower": {
        "base_speed": 8,
        "turn_speed_left": 6,
        "turn_speed_right": 6,
        "crossing_duration": 3.0,
        "cross_pre_forward_speed": 8,
        "cross_pre_forward_duration": 2.7,
        "cross_pre_stop_duration": 1.0,
        "rotate_min_duration": 5,
        "rotate_line_mid_min_count": 1,
        "rotate_line_side_max_count": 3,
        "rotate_early_stop_on_side": true,
        "rotate_line_side_min_count": 1,
        "plan_lost_line_hold_sec": 1.2,
        "plan_lost_line_warn_period": 0.6,
        "cross_plan_name": "a19",
        "plan_end_state": "stop",
        "auto_on_plan_select": true,
        "tracking": {
            "strategy": "huskylens",
            "strict_mode": true,
            "line_frame_stale_sec": 0.4,
            "huskylens_frame_stale_sec": 0.6,
            "log_invalid_period": 1.0
        },
        "topics": {
            "line_frame": "/line_sensors/frame",
            "cmd_vel": "/motor_cmd",
            "auto_mode": "/auto_mode",
            "plan_select": "/plan_select",
            "pick_robot": "/pick_robot",
            "plan_status": "/plan_status",
            "plan_callback": "/plan_callback"
        },
        "service": {
            "set_auto_mode": "/set_auto_mode"
        },
        "huskylens": {
            "enabled": true,
            "topic_frame": "/huskylens/frame",
            "max_abs_error": 120,
            "control_gain": 1.0,
            "deadband": 1.0,
            "fallback_on_invalid": false
        },
        "huskylens_raw": {
            "enabled": false,
            "topic_frame": "/huskylens/frame",
            "image_center_x": 160,
            "speed_forward": 8,
            "speed_rotate": 6,
            "speed_lateral": 6,
            "alpha_tail": 0.35,
            "alpha_angle": 0.25,
            "tail_deadband_px": 8,
            "angle_deadband_deg": 1.0,
            "tail_hysteresis_px": 2.0,
            "angle_hysteresis_deg": 0.5,
            "invalid_timeout_sec": 0.4,
            "min_command_hold_ms": 250,
            "publish_rate_hz": 20,
            "debug_log_period": 0.5
        },
        "plan_alias": {
            "0": "clear",
            "1": "a19",
            "2": "a18",
            "3": "a17",
            "4": "a16",
            "5": "a15"
        }
    },
    "motor_driver": {
        "serial": {
            "port": "/dev/ttyUSB0",
            "baudrate": 115200,
            "timeout": 0.1
        },
        "subscribe": {
            "cmd_vel": "/motor_cmd"
        },
        "topics": {
            "debug_toggle": "/debug_logs_toggle"
        }
    },
    "manual_control": {
        "base_speed": 10,
        "manual_override_on_input": true,
        "topics": {
            "vr_control": "/VR_control",
            "pick_robot": "/pick_robot",
            "cmd_vel": "/motor_cmd",
            "auto_mode": "/auto_mode"
        },
        "service": {
            "set_auto_mode": "/set_auto_mode"
        }
    },
    "huskylens_sensor": {
        "serial": {
            "port": "/dev/ttyACM1",
            "baudrate": 9600,
            "timeout": 0.2
        },
        "publish": {
            "topic_frame": "/huskylens/frame",
            "topic_valid": "/huskylens/valid",
            "rate_hz": 20
        },
        "reconnect_period_sec": 2.0,
        "fallback_ports": [
            "/dev/ttyACM2",
            "/dev/ttyACM1",
            "/dev/ttyACM0"
        ],
        "scan_prefixes": [
            "/dev/ttyACM",
            "/dev/ttyUSB",
            "COM"
        ],
        "parse_log_every": 20,
        "status_log_period": 2.0
    },
    "mqtt_bridge": {
        "broker": {
            "address": "127.0.0.1",
            "port": 1883
        },
        "topics": {
            "vr_control": "VR_control",
            "pick_robot": "pick_robot",
            "plan_select": "plan_select",
            "debug_toggle": "/debug_logs_toggle",
            "robot_logs": "robot_logs",
            "camera_face_ros": "/face/camera",
            "camera_face_mqtt": "face/camera",
            "plan_status_ros": "/plan_status",
            "plan_status_mqtt": "plan_status",
            "plan_message_ros": "/plan_message",
            "plan_message_mqtt": "plan_message",
            "huskylens_frame_ros": "/huskylens/frame",
            "huskylens_frame_mqtt": "huskylens/frame",
            "huskylens_valid_ros": "/huskylens/valid",
            "huskylens_valid_mqtt": "huskylens/valid"
        },
        "keyboard": {
            "forward": "w",
            "backward": "s",
            "left": "a",
            "right": "d",
            "stop": " ",
            "rotate_left": "j",
            "rotate_right": "p",
            "toggle_debug_logs": "e",
            "toggle_auto": "k",
            "quit": "q"
        },
        "echo_suppress_window_sec": 0.35,
        "log_control": {
            "bridge_in_enabled": false,
            "bridge_out_enabled": false,
            "bridge_traffic_period": 1.0,
            "plan_status_enabled": true,
            "plan_status_period": 0.5,
            "plan_message_enabled": true,
            "plan_message_period": 0.5,
            "huskylens_frame_enabled": false,
            "huskylens_frame_period": 2.0,
            "huskylens_valid_enabled": true,
            "huskylens_valid_log_on_change": true
        },
        "plan_keys": {
            "0": "clear",
            "1": "a19",
            "2": "a18",
            "3": "a17",
            "4": "a16",
            "5": "a15"
        },
        "room_plans": {
            "a19": "a19",
            "a18": "a18",
            "a17": "a17",
            "a16": "a16",
            "a15": "a15",
            "1": "a19",
            "2": "a18",
            "3": "a17",
            "4": "a16",
            "5": "a15"
        },
        "camera_face_forward": {
            "enabled": false
        },
        "camera_face_plan_message": {
            "enabled": true,
            "require_plan_autoline": true,
            "id_messages": {
               "0": "say: Xin vui lòng nhường đường giúp con di chuyển ạ. Con xin cảm ơn.",
                "1": "say: Con kính chào bác Chiến. Chúc Giám đốc một ngày làm việc hiệu quả và nhiều sức khỏe.",
                "2": "say: Con Kính chào Bác Minh. Chúc Bác một ngày làm việc thành công.",
                "3": "say: Con chào Thầy Thơ. Chúc Thầy một ngày làm việc hiệu quả và nhiều năng lượng.",
                "4": "say: Con chào Thầy Nhân. Chúc Thầy một ngày làm việc thành công và nhiều sức khỏe."
            }
        },
        "log_bridge": {
            "enabled": true,
            "ros_topic": "/rosout",
            "source_nodes": [
                "line_follower"
            ],
            "keywords": [
                "[PLAN_STATUS]",
                "[PLAN]"
            ]
        }
    }
}
